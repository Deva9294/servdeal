NODE_ENV=development
PORT=5000
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000,https://localhost:3000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/servdeal?retryWrites=true&w=majority

JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_REFRESH_EXPIRE=30d
OTP_EXPIRE_MINUTES=10
OTP_EXPOSE_IN_RESPONSE=false

# PAYU (get from your PayU merchant dashboard)
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt

# SMS OTP PROVIDER
SMS_PROVIDER=auto

# Twilio Configuration (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1xxxxxxxxxx

# MSG91 Configuration (recommended for India)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=SRVDEA
MSG91_FLOW_TEMPLATE_ID=your_flow_template_id

# Cloudinary (get from cloudinary.com → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=ServDeal <noreply@servdeal.in>

# Business Configuration
WHATSAPP_NUMBER=+91xxxxxxxxxx
PLATFORM_COMMISSION=15
GST_PERCENT=18